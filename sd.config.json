{
  "source": [
    "tokens/**/*.json"
  ],
  "log": {
    "verbosity": "default"
  },
  "platforms": {
    "css": {
      "transformGroup": "css",
      "prefix": "token",
      "buildPath": "dist/tokens/",
      "files": [
        {
          "destination": "tokens.css",
          "format": "css/variables"
        }
      ]
    },
    "js": {
      "transformGroup": "js",
      "buildPath": "dist/tokens/",
      "files": [
        {
          "destination": "tokens.js",
          "format": "javascript/esm"
        },
        {
          "destination": "tokens.d.ts",
          "format": "typescript/esm-declarations"
        }
      ]
    },
    "json": {
      "transformGroup": "js",
      "buildPath": "dist/tokens/",
      "files": [
        {
          "destination": "tokens.json",
          "format": "json/nested"
        }
      ]
    }
  }
}